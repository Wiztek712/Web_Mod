{
  "manifest_version": 3,
  "name": "Accueil Personnalisé",
  "version": "1.0",
  "description": "Une page d'accueil dynamique pour afficher les favoris.",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs"
  ],
  "chrome_url_overrides": {
    "newtab": "app/index.html"
  },
  "action": {
    "default_popup": "app/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["../favicon.ico", "node_modules/swapy/dist/swapy.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
